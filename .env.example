# ============================================================================
# hermes-web-relay — environment variables
# Copy to .env on the host that runs each half. NEVER commit a real .env.
# ============================================================================

# --- Browser auth (phone -> Coolify) -----------------------------------------
# Pre-shared password for the web UI. Type once per device, then a signed
# cookie (HttpOnly + Secure + SameSite=Lax) lasts 30 days.
WEBRELAY_PASSWORD=change-me-to-a-long-random-string

# Secret used by itsdangerous to sign session cookies. MUST be a long random
# string. Rotate to invalidate all active sessions.
WEBRELAY_SESSION_SECRET=replace-with-32-bytes-of-random-hex

# --- Local agent -> server auth ---------------------------------------------
# SHA256 hex digest of the bearer token the local agent presents on the
# outbound WebSocket at /api/relay/ws. The plaintext token lives only on the
# local machine (see ~/.hermes/vault.json -> webrelay.bearer_token).
# Generate it locally with:
#   python -c "import secrets,hashlib;print(hashlib.sha256(secrets.token_urlsafe(48).encode()).hexdigest())"
WEBRELAY_RELAY_TOKEN_HASH=replace-with-sha256-hex

# --- Storage -----------------------------------------------------------------
# Filesystem path to the SQLite database. On Coolify mount a persistent
# volume (e.g. /data) so chat history + ledger snapshots survive redeploys.
WEBRELAY_DB_PATH=./webrelay.db

# --- Public URL --------------------------------------------------------------
# Externally reachable base URL of this server. Used for absolute links in
# templates and for the local agent's first registration ping.
WEBRELAY_BASE_URL=http://localhost:8000
